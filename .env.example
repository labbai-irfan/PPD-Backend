NODE_ENV=development
PORT=3000
API_PREFIX=api

MONGODB_URI=mongodb://localhost:27017/ppd-store

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=change-me-to-a-random-64-char-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=change-me-to-a-different-random-64-char-string
JWT_REFRESH_EXPIRES=7d

BCRYPT_ROUNDS=12
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=30

OTP_LENGTH=6
OTP_TTL_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
RESET_TOKEN_TTL_MINUTES=30

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@ppdstore.com

CORS_ORIGIN=http://localhost:5173
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

FREE_SHIPPING_THRESHOLD=499
SHIPPING_FEE=40
REFERRAL_REWARD=200
LOYALTY_POINTS_PER_RUPEE=1

# Payments — leave both empty to use the built-in mock gateway.
# Set both to your Razorpay credentials to switch to real Razorpay checkout.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Secret configured on the Razorpay dashboard webhook (Settings > Webhooks).
# Point the webhook at POST /api/v1/payments/webhook with events
# payment.captured + payment.failed. Leave empty to disable webhook handling.
RAZORPAY_WEBHOOK_SECRET=
